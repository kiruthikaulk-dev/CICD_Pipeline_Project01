pipeline {
    agent any
    stages{
        stage('Clone Code from Github') {
            steps{
                git 'https://github.com/kiruthikaulk-dev/CICD_Pipeline_Project01.git' 
            } 
        }
        stage('Build Docker Image'){
            steps{
                bat 'docker build -t kiruthika91/python-devops .'
            }
        }
        stage('Push image to docker hub'){
            steps{
                bat 'docker push kiruthika91/python-devops'
            }
        }
        stage('Deploy Kubernetes'){
            steps{
                bat 'kubectl apply -f deployment.yml'
                bat 'kubectl apply -f service.yml'
            }
        }
    }

}